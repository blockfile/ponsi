# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# DRY_RUN=true simulates all on-chain calls (safe, no funds touched).
# Set to false ONLY after a funded wallet + RPC are configured and validated.
DRY_RUN=true

# ── Robinhood Chain (EVM) ────────────────────────────────────────────────────
# Defaults target Robinhood Chain mainnet (chain id 4663).
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
# Blockscout instance (REST API, no key needed) used by the preflight check.
EXPLORER_API=https://robinhoodchain.blockscout.com

# Signing wallet: 0x-prefixed hex private key. MUST be the wallet that DEPLOYED
# the token on NOXA Fun — the creator fee share is paid to the deployer address.
# In DRY_RUN you can leave this blank — an ephemeral wallet is generated.
WALLET_PRIVATE_KEY=

# ── NOXA Fun contracts (Robinhood Chain defaults — override for other chains) ─
NOXA_FACTORY=0xD9eC2db5f3D1b236843925949fe5bd8a3836FCcB
NOXA_LOCKER=0x7F03effbd7ceB22A3f80Dd468f67eF27826acD85
NOXA_FEE_VAULT=0x9eFdC1A8e6E94f16A228e44f3025E1f346EE0417
WETH_ADDRESS=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
SWAP_ROUTER=0xCaf681a66D020601342297493863E78C959E5cb2
# Observed creator share of the WETH-side LP fees paid out by collect() (%).
CREATOR_FEE_SHARE_PCT=35

# ── Token ────────────────────────────────────────────────────────────────────
# TOKEN_ADDRESS is YOUR token launched on NOXA Fun. Its creator fees fund the
# cycle; the bot buys it and pairs it into permanently-locked liquidity.
TOKEN_ADDRESS=
TOKEN_SYMBOL=TOKEN

# ── Buyback-and-burn loop ────────────────────────────────────────────────────
# Each claim: buy the token with BUY_PCT of the claimed WETH and BURN those
# tokens (send to DEAD_ADDRESS — out of circulation forever). The remaining
# (100 - BUY_PCT)% is unwrapped to native ETH and kept in the wallet to pay gas.
BUY_PCT=80                        # % of each claim used to buy + burn the token
SLIPPAGE_PCT=5                    # Uniswap V3 buy-swap slippage tolerance, percent
GAS_RESERVE_ETH=0.005             # native ETH kept back for gas, never wrapped
# Burn sink for the bought tokens (default is the canonical EVM dead address).
DEAD_ADDRESS=0x000000000000000000000000000000000000dEaD

# ── Trigger ──────────────────────────────────────────────────────────────────
# The scheduler checks on this timer and runs a cycle once the claimable fees are
# worth CLAIM_THRESHOLD_USD. Set the threshold to 0 to claim whatever has accrued
# on every tick instead (pure timer mode). POST /api/run always bypasses it.
POLL_SCHEDULE=*/1 * * * *         # check every minute
CLAIM_THRESHOLD_USD=0             # 0 = buy+burn every minute on whatever accrued; raise to batch
# DRY_RUN only: simulated ETH accrued to the fee vault per tick (so cycles have fees).
DRY_RUN_FEE_PER_POLL=0.01

# ── Market data (optional) ───────────────────────────────────────────────────
# DexScreener chain slug used for /stats market cap; leave default until listed.
DEXSCREENER_CHAIN_ID=robinhood

# ── Storage (MongoDB) ────────────────────────────────────────────────────────
# Local mongod, or a MongoDB Atlas SRV URI (mongodb+srv://user:pass@cluster/...).
MONGODB_URI=
MONGODB_DB=noxaliqui

# ── Frontend / CORS ──────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins that may call the API.
# Use "*" to allow any origin (not recommended). Non-browser calls always pass.
CORS_ORIGINS=

# Secret protecting POST /api/run|pause|resume. Blank = open (dev only).
# In production set a long random string; send it as header x-api-key: <key>.
API_KEY=
